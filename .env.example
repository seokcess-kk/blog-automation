# blog-automation 환경변수 설정
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요.

# API Keys (필수)
ANTHROPIC_API_KEY=sk-ant-api03-...     # Claude API 키 (원고 생성)
GOOGLE_AI_API_KEY=AIza...               # Google AI API 키 (이미지 생성, 심층 분석)

# 네이버 검색광고 API (선택)
NAVER_AD_CUSTOMER_ID=
NAVER_AD_ACCESS_LICENSE=
NAVER_AD_SECRET_KEY=

# 네이버 오픈 API - 블로그 검색 (선택)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Supabase (선택 - DB 사용 시)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJhbGciOi...

# 블로그 계정 (발행 시 필요)
BLOG_A_USERNAME=
BLOG_A_PASSWORD=
BLOG_A_BLOG_ID=
BLOG_B_USERNAME=
BLOG_B_PASSWORD=
BLOG_B_BLOG_ID=

# Slack 알림 (선택)
SLACK_WEBHOOK_URL=

# 발행 모드: conservative | normal | aggressive
PUBLISH_MODE=conservative

# 브라우저 모드 (기본 false - 봇 탐지 우회)
HEADLESS=false
